{
  "name": "meme-trend-globe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare:map": "node -e \"require('fs').copyFileSync('node_modules/world-atlas/countries-110m.json','public/world-110m.json')\"",
    "fetch": "tsx scripts/fetch-trends.ts",
    "fetch:mock": "tsx scripts/fetch-trends.ts --mock",
    "postfetch": "tsx scripts/validate-data.ts",
    "postfetch:mock": "tsx scripts/validate-data.ts",
    "predev": "npm run prepare:map",
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.scripts.json",
    "build": "npm run typecheck && npm run prepare:map && npm run fetch:mock && vite build",
    "build:live": "npm run typecheck && npm run prepare:map && npm run fetch && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "globe.gl": "^2.34.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/topojson-client": "^3.1.5",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
